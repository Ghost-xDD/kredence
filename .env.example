# ─── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── GitHub ────────────────────────────────────────────────────────────────────
# Generate at https://github.com/settings/tokens (read:org, public_repo scopes)
GITHUB_TOKEN=ghp_...

# ─── Storacha ──────────────────────────────────────────────────────────────────
# 1. Install:       npm i -g @web3-storage/w3cli
# 2. Login:         w3 login your@email.com
# 3. Create space:  w3 space create credence
# 4. Create key:    w3 key create > key.out
# 5. Create proof:  w3 delegation create --can 'store/add' --can 'upload/add' $(head -1 key.out) | base64 > proof.b64
# STORACHA_PRINCIPAL = line 2 of key.out (the did:key:... value)
# STORACHA_PROOF     = contents of proof.b64
STORACHA_PRINCIPAL=did:key:...
STORACHA_PROOF=...

# ─── ERC-8004 / Chain ──────────────────────────────────────────────────────────
# Operator wallet private key (the wallet that will register agents)
# Use a dedicated wallet — not your main wallet
OPERATOR_PRIVATE_KEY=0x...
# Operator wallet public address (derived from the private key above)
OPERATOR_WALLET=0x...

# Base Sepolia RPC (default: public endpoint, replace with Alchemy/Infura for reliability)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Agent Identity (populated after Phase 1 ERC-8004 registration) ────────────
SCOUT_AGENT_ID=
EVIDENCE_AGENT_ID=
ADVERSARIAL_AGENT_ID=
SYNTHESIS_AGENT_ID=

# ─── Hypercerts (ATProto) ──────────────────────────────────────────────────────
# Create a Bluesky account for the Credence agent, then generate an App Password:
#   1. Go to https://bsky.app → Settings → Privacy and Security → App Passwords
#   2. Create a password named "credence-agent"
# The handle is your full Bluesky handle, e.g. credence-agent.bsky.social
HYPERCERTS_HANDLE=credence-agent.bsky.social
HYPERCERTS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
