{
  "name": "credence",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:storacha": "pnpm build:packages && cd scripts && ../node_modules/.bin/tsx test-storacha.ts",
    "build:packages": "pnpm --filter './packages/*' build",
    "test:scout": "pnpm build:packages && cd scripts && ../node_modules/.bin/tsx test-scout.ts",
    "test:evidence": "pnpm build:packages && cd scripts && ../node_modules/.bin/tsx test-evidence.ts",
    "test:adversarial": "pnpm build:packages && cd scripts && ../node_modules/.bin/tsx test-adversarial.ts",
    "test:pipeline": "pnpm build:packages && cd scripts && ../node_modules/.bin/tsx test-pipeline.ts"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
