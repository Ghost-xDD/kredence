{
  "name": "@credence/server",
  "version": "0.1.0",
  "description": "Credence pipeline WebSocket server — streams real-time agent events over WS/WSS",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@credence/agents": "workspace:*",
    "@credence/storage": "workspace:*",
    "@credence/types": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "nanoid": "^5.1.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.14",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
